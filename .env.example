# Required: absolute path to your Godot project on the host
GODOT_PROJECT_PATH=/absolute/path/to/your/godot/project

# Directory containing your Claude Code user config (skills/, CLAUDE.md, etc.)
# Defaults to $HOME/.claude if you use the standard Claude Code setup
CLAUDE_USER_CONFIG_DIR=$HOME/.claude

# Godot headless CLI version (default: 4.6.1)
# GODOT_VERSION=4.6.1
